{
  "name": "Temperature Monitor v1",
  "version": "1.1.0",
  "description": "A complete demo: temperature sensor (LM35) with I²C LCD display on Arduino Uno. Exercises circuit, PCB, CAD, firmware, and BOM workspaces.",
  "board": "arduino:avr:uno",
  "files": {
    "sketch": "firmware/temperature-monitor.ino",
    "circuit": "schematic.json",
    "pcb": "pcb.json",
    "cad": "cad.json"
  },
  "bom": [
    { "refDesignators": ["U1"], "value": "Arduino Uno R3", "package": "DIP-28", "quantity": 1, "description": "Microcontroller board" },
    { "refDesignators": ["U2"], "value": "LM35", "package": "TO-92", "quantity": 1, "description": "Precision temperature sensor" },
    { "refDesignators": ["LCD1"], "value": "LCD 16×2 I²C", "package": "lcd_i2c_16x2", "quantity": 1, "description": "I²C serial LCD module (address 0x27)" },
    { "refDesignators": ["R1"], "value": "10kΩ", "package": "axial_0.4in", "quantity": 1, "description": "Pull-up resistor for I²C SDA" },
    { "refDesignators": ["R2"], "value": "10kΩ", "package": "axial_0.4in", "quantity": 1, "description": "Pull-up resistor for I²C SCL" },
    { "refDesignators": ["R3"], "value": "220Ω", "package": "axial_0.4in", "quantity": 1, "description": "LCD backlight current limit" },
    { "refDesignators": ["C1"], "value": "100nF", "package": "cap_disc_5mm", "quantity": 1, "description": "Decoupling capacitor for LM35" },
    { "refDesignators": ["C2"], "value": "100µF", "package": "cap_rad_5mm", "quantity": 1, "description": "Bulk decoupling for Arduino VIN" }
  ]
}
