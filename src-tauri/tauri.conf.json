{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Forge",
  "version": "1.0.0",
  "identifier": "com.forge.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Forge",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "decorations": true,
        "fullscreen": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:* https://api.openai.com https://api.anthropic.com http://localhost:11434; img-src 'self' data:; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "AI-native hardware engineering IDE",
    "longDescription": "Forge — design enclosures, schematics, PCBs, and firmware in one AI-assisted desktop IDE. Circuit + PCB layout, 3D CAD, BOM generation, compile & upload to Arduino-compatible boards.",
    "copyright": "© 2026 Forge",

    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "wix": null
    }
  }
}
